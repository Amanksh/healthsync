<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Invoice {{invoiceNumber}}</title>
    <style>
        body {
            font-family: 'Helvetica Neue', 'Helvetica', Helvetica, Arial, sans-serif;
            color: #555;
            max-width: 800px;
            margin: auto;
            padding: 30px;
            font-size: 16px;
            line-height: 24px;
        }
        .invoice-box {
            border: 1px solid #eee;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.15);
            padding: 30px;
        }
        .header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
        }
        .header h1 {
            color: #333;
            margin: 0;
        }
        .hospital-info {
            text-align: right;
        }
        .invoice-details {
            margin-bottom: 40px;
            border-bottom: 1px solid #eee;
            padding-bottom: 20px;
        }
        .patient-info {
            margin-bottom: 20px;
        }
        table {
            width: 100%;
            line-height: inherit;
            text-align: left;
            border-collapse: collapse;
        }
        table td {
            padding: 5px;
            vertical-align: top;
        }
        table tr.heading td {
            background: #eee;
            border-bottom: 1px solid #ddd;
            font-weight: bold;
        }
        table tr.item td {
            border-bottom: 1px solid #eee;
        }
        table tr.total td:nth-child(2) {
            border-top: 2px solid #eee;
            font-weight: bold;
        }
        .text-right {
            text-align: right;
        }
        .status-paid {
            color: green;
            font-weight: bold;
            border: 2px solid green;
            padding: 5px 10px;
            border-radius: 5px;
            display: inline-block;
        }
        .status-pending {
            color: orange;
            font-weight: bold;
            border: 2px solid orange;
            padding: 5px 10px;
            border-radius: 5px;
            display: inline-block;
        }
    </style>
</head>
<body>
    <div class="invoice-box">
        <div class="header">
            <div>
                <h1>INVOICE</h1>
                <p><strong>#{{invoiceNumber}}</strong><br>
                Date: {{date}}</p>
                {{#if paymentStatus}}
                    <div class="status-{{paymentStatus}}">{{paymentStatus}}</div>
                {{/if}}
            </div>
            <div class="hospital-info">
                <h3>{{hospitalName}}</h3>
                {{#if hospitalAddress}}
                    {{hospitalAddress}}<br>
                {{/if}}
                {{#if hospitalCity}}
                    {{hospitalCity}}, {{hospitalState}} {{hospitalZip}}<br>
                {{/if}}
                {{#if hospitalPhone}}
                    Phone: {{hospitalPhone}}
                {{/if}}
            </div>
        </div>

        <div class="invoice-details">
            <div class="patient-info">
                <strong>Bill To:</strong><br>
                {{patientName}}<br>
                {{#if patientAddress}}
                    {{patientAddress}}<br>
                    {{patientCity}}, {{patientState}} {{patientZip}}
                {{/if}}
            </div>
        </div>

        <table>
            <tr class="heading">
                <td>Item</td>
                <td class="text-right">Price</td>
                <td class="text-right">Qty</td>
                <td class="text-right">Total</td>
            </tr>

            {{#each items}}
            <tr class="item">
                <td>{{description}} <br><small style="color: #888;">{{category}}</small></td>
                <td class="text-right">{{unitPrice}}</td>
                <td class="text-right">{{quantity}}</td>
                <td class="text-right">{{total}}</td>
            </tr>
            {{/each}}

            <tr class="total">
                <td colspan="3" class="text-right">Subtotal:</td>
                <td class="text-right">{{subtotal}}</td>
            </tr>
            <tr>
                <td colspan="3" class="text-right">Tax ({{taxRate}}%):</td>
                <td class="text-right">{{taxAmount}}</td>
            </tr>
            {{#if discount}}
            <tr>
                <td colspan="3" class="text-right">Discount:</td>
                <td class="text-right">-{{discount}}</td>
            </tr>
            {{/if}}
            <tr>
                <td colspan="3" class="text-right"><strong>Total:</strong></td>
                <td class="text-right"><strong>{{totalAmount}}</strong></td>
            </tr>
        </table>
        
        {{#if notes}}
        <div style="margin-top: 40px; border-top: 1px solid #eee; padding-top: 10px;">
            <strong>Notes:</strong><br>
            {{notes}}
        </div>
        {{/if}}
    </div>
</body>
</html>
